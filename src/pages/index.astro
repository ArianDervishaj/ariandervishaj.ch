---
import Layout from "../layouts/Layout.astro";
import Experience from "../components/portfolio/Experience.astro";
import HeroIndex from "../components/portfolio/HeroIndex.astro";
import ListProjects from "../components/portfolio/ListProjects.astro";
import { getCollection } from "astro:content";
import Education from "../components/portfolio/Education.astro";
import Certifications from "../components/portfolio/Certifications.astro";

const [staticData] = await getCollection("staticData");
const { pageTitle, pageDescription, OGImage } = staticData.data;
---

<Layout
  pageTitle={pageTitle}
  description={pageDescription}
  ogimage={{ alt: OGImage.alt, url: OGImage.url }}
>
  <HeroIndex />
  <Certifications/>
  <Experience />
  <Education />
  <ListProjects />
  <!-- <Contact /> -->
</Layout>
