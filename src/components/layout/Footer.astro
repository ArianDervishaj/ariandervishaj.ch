---
import Social from "../ui/Social.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const [staticData] = await getCollection("staticData");
const { github, alias, linkedin, linkedinIconName, githubIconName } =
  staticData.data;
---

<footer
  class="relative bottom-0 w-full px-8 py-12 max-sm:px-4 dark:bg-zinc-950 bg-white border-t-2 border-mint-200/50 dark:border-mint-900/50"
  role="contentinfo"
  aria-label="Site footer"
>
  <div
    class="mx-auto max-w-7xl flex flex-col items-center justify-center gap-6 text-center"
  >
    <div
      class="flex items-center justify-center gap-6"
      role="group"
      aria-label="Social media links"
    >
      <Social
        link={github}
        iconName={githubIconName}
        label={`Visit ${alias} on GitHub`}
      />
      <Social
        link={linkedin}
        iconName={linkedinIconName}
        label={`Visit ${alias} on LinkedIn`}
      />
    </div>

    <a
      target="_blank"
      rel="noopener noreferrer"
      href="https://github.com/EFEELE/NeonMint"
      class="text-sm font-medium text-blacktext/60 dark:text-gray-400 hover:text-mint-500 dark:hover:text-mint-400 transition-colors"
      aria-label="About the website development"
    >
      Template by EFEELE
    </a>
  </div>
</footer>
