---
import { getLanguage } from "../../utils/languages";

interface Props {
  lang: string;
  linkEnabled?: boolean;
}

const { lang, linkEnabled = true } = Astro.props as Props;

const baseClasses = [
  "inline-flex items-center justify-center",
  "px-4 py-2",
  "text-sm font-semibold",
  "bg-white text-gray-800",
  "border-2 border-emerald-500",
  "rounded-full shadow-md",
  "transition-all duration-300 ease-in-out",
  "hover:bg-emerald-500 hover:text-white hover:shadow-lg hover:scale-105",
  "max-sm:px-3 max-sm:py-1.5 max-sm:text-xs",
].join(" ");

const selectedLanguage = getLanguage(lang);
---

{
  linkEnabled ? (
    <a
      class="cursor-pointer inline-block"
      href={`/blog/techs/${lang}`}
      aria-label={`View articles about ${selectedLanguage.name}`}
    >
      <span class={baseClasses}>{selectedLanguage.name}</span>
    </a>
  ) : (
    <span class={`${baseClasses} cursor-default`}>{selectedLanguage.name}</span>
  )
}
