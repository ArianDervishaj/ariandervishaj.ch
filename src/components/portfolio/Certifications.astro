---
import Heading from "../ui/Heading.astro";
import { Icon } from "astro-icon/components";

const CERTIFICATIONS = [
    {
        date: "June 2025",
        title: "CCNA: Introduction to Networks",
        issuer: "Cisco Networking Academy",
        description:
            "Foundational networking certification covering IP addressing, Ethernet protocols, network fundamentals, and security basics. Configured connectivity between switches, routers, and end devices.",
        status: "completed",
        verificationUrl:
            "https://www.credly.com/badges/350df126-24f9-41fc-9852-a770199be528",
        credentialId: "350df126-24f9-41fc-9852-a770199be528",
    },
    {
        date: "Present",
        title: "eLearnSecurity Junior Penetration Tester (eJPT)",
        issuer: "INE Security",
        description:
            "Entry-level penetration testing certification covering network security, web application testing, vulnerability assessment, and exploitation techniques. Demonstrating practical skills in reconnaissance, enumeration, and security analysis through hands-on labs.",
        status: "in-progress",
    },
    
];
---

<section class="py-8 px-8 max-md:py-4 mb-4 scroll-m-16" id="certifications">
    <div class="flex flex-col pt-8 max-w-6xl mx-auto">
        <div class="flex gap-4 items-center justify-center mb-12">
            <Icon
                class="text-4xl dark:text-white text-blacktext"
                name="mdi:certificate-outline"
            />
            <Heading textGradient="Certifications" level={2} />
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            {
                CERTIFICATIONS.map((cert, index) => (
                    <article
                        role="article"
                        aria-labelledby={`cert-title-${index}`}
                        class="group relative overflow-hidden rounded-2xl bg-white dark:bg-zinc-900 border-2 border-mint-200 dark:border-mint-900 hover:border-mint-400 dark:hover:border-mint-600 transition-all duration-300 hover:shadow-[0_10px_40px_rgba(13,188,130,0.15)]"
                    >
                        {/* Background gradient effect */}
                        <div class="absolute inset-0 bg-gradient-to-br from-mint-50/50 to-transparent dark:from-mint-950/30 dark:to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />

                        <div class="relative p-6 flex flex-col gap-4 h-full">
                            {/* Header: Date and Status */}
                            <div class="flex items-center justify-between gap-4 flex-wrap">
                                <time class="text-sm font-semibold text-mint-600 dark:text-mint-400">
                                    {cert.date}
                                </time>

                                {cert.status === "completed" ? (
                                    <a
                                        href={cert.verificationUrl}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-2 bg-green-500 dark:bg-green-600 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg hover:bg-green-600 dark:hover:bg-green-700 transition-colors"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-4 w-4"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path
                                                fill-rule="evenodd"
                                                d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                                clip-rule="evenodd"
                                            />
                                        </svg>
                                        Verify
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-3 w-3"
                                            viewBox="0 0 20 20"
                                            fill="currentColor"
                                        >
                                            <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" />
                                            <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" />
                                        </svg>
                                    </a>
                                ) : (
                                    <span class="inline-flex items-center gap-2 bg-orange-500 dark:bg-orange-600 text-white text-xs font-bold px-3 py-1.5 rounded-full shadow-lg">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="h-4 w-4 animate-spin"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                                            />
                                        </svg>
                                        In Progress
                                    </span>
                                )}
                            </div>

                            {/* Title */}
                            <h3
                                id={`cert-title-${index}`}
                                class="text-2xl font-bold text-blacktext dark:text-white leading-tight"
                            >
                                {cert.title}
                            </h3>

                            {/* Issuer */}
                            <p class="text-lg font-semibold text-mint-600 dark:text-mint-400">
                                {cert.issuer}
                            </p>

                            {/* Description */}
                            <p class="text-base text-blacktext/80 dark:text-gray-300 leading-relaxed flex-grow">
                                {cert.description}
                            </p>

                            {/* Credential ID (only for completed) */}
                            {cert.status === "completed" &&
                                cert.credentialId && (
                                    <div class="pt-4 border-t border-mint-200 dark:border-mint-900">
                                        <div class="text-xs text-blacktext/60 dark:text-gray-500 font-mono">
                                            Credential ID: {cert.credentialId}
                                        </div>
                                    </div>
                                )}
                        </div>
                    </article>
                ))
            }
        </div>
    </div>
</section>
